# Which business data source to use: mock | osm | google
#   mock   - sample Bangalore restaurants, no keys (for trying the app)
#   osm    - real OpenStreetMap data via Overpass, free, NO API key, any category
#   google - Google Places (most complete); needs a billing account + key
LEAD_SOURCE=mock

# Required only when LEAD_SOURCE=google
# Create a key at https://console.cloud.google.com/ with the Places API enabled.
GOOGLE_PLACES_API_KEY=

# Only needed if you want to point at OSM mirrors (defaults work out of the box).
# OVERPASS_URL=https://overpass-api.de/api/interpreter
# NOMINATIM_URL=https://nominatim.openstreetmap.org/search

# Per-request website check timeout in seconds
WEBSITE_CHECK_TIMEOUT=10
